root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.json]
indent_size = 2

[*.{kt,kts}]
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = false
ktlint_code_style = official
ktlint_experimental_function-signature = enabled
ktlint_experimental_traling-comma = enabled
ktlint_function_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = multiline

[*.{yml,yaml}]
indent_size = 2

[.prettierrc]
indent_size = 2
